{
  "entities": {
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice generated by the user",
      "type": "object",
      "properties": {
        "invoiceNum": { "type": "string" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string", "description": "Optional due date" },
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "companyRegNum": { "type": "string" },
        "companyContact": { "type": "string" },
        "companyLogo": { "type": "string" },
        "clientName": { "type": "string" },
        "clientAddress": { "type": "string" },
        "clientContact": { "type": "string" },
        "taxRate": { "type": "number" },
        "discount": { "type": "number" },
        "notes": { "type": "string" },
        "terms": { "type": "string" },
        "template": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" }
            }
          }
        }
      },
      "required": ["invoiceNum", "userId", "items"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Settings for the user",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "companyRegNum": { "type": "string" },
        "companyContact": { "type": "string" },
        "companyLogo": { "type": "string" },
        "defaultTaxRate": { "type": "number" },
        "defaultTerms": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile data"
    },
    "users/{userId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Collection of invoices for the user"
    }
  }
}
