rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow write: if isOwner(userId) && isValidUserProfile(request.resource.data);

      function isValidUserProfile(data) {
        return data.keys().hasAll(['companyName']) &&
               data.companyName is string && data.companyName.size() <= 200;
      }
    }

    // Invoices
    match /users/{userId}/invoices/{invoiceId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidInvoice(request.resource.data) && isValidId(invoiceId);
      allow update: if isOwner(userId) && isValidInvoice(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['companyName', 'companyAddress', 'companyRegNum', 'companyContact', 'companyLogo', 'clientName', 'clientAddress', 'clientContact', 'invoiceNum', 'issueDate', 'dueDate', 'items', 'taxRate', 'discount', 'notes', 'terms', 'template', 'updatedAt'])
      );
      allow delete: if isOwner(userId);

      function isValidInvoice(data) {
        return data.userId == request.auth.uid &&
               data.invoiceNum is string && data.invoiceNum.size() <= 50 &&
               data.items is list && data.items.size() <= 100 &&
               (data.items.size() == 0 || data.items[0].description is string);
      }
    }
  }
}
